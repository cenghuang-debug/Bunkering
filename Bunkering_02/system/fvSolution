FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "rho.*"
    {
        solver          diagonal;
    }

    p
    {
/*
        solver          GAMG;
        tolerance       1e-8;
        relTol          0.0;     // force iterations, do not early-exit
        smoother        DICGaussSeidel;
        nCellsInCoarsestLevel 50;
        minIter 1;     // <- VERY IMPORTANT
*/        
        solver           PCG;
        preconditioner   DIC;
        tolerance        1e-8;
        relTol           0.0;
    }

    pFinal
    {
        $p;
        relTol           0;
    }

    "(U|h|k|epsilon|omega)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.0;
        minIter 1;     // <- VERY IMPORTANT
    }

    "(U|h|k|epsilon|omega)Final"
    {
        $U;
        relTol          0;
    }

    Yi
    {
        $hFinal;
    }

    Phi
    {
        $p;
    }
}

PIMPLE
{
    momentumPredictor on; //off;
    nOuterCorrectors 3; //1;
    nCorrectors     2;
    nNonOrthogonalCorrectors 2; //1; 


    residualControl
    {
        // Absolute stopping criteria (tolerance) + relative (relTol)
        p
        {
            tolerance   1e-4;
            relTol      0.0;   // 0.0 = force absolute stopping criterion
        }
        U
        {
            tolerance   1e-5;
            relTol      0.0;
        }
        h
        {
            tolerance   1e-6;
            relTol      0.0;
        }
        "(H2|O2|H2O|N2)"
        {
            tolerance   1e-6;
            relTol      0.0;
        }
    }
}


potentialFlow
{
    nNonOrthogonalCorrectors 10;
}

relaxationFactors
{
    equations
    {
        "(p).*"                                0.3;
        "(U|k|epsilon).*"                      0.7;
        "(H2|O2|H2O|air|h).*"                  0.7;
    }
}
