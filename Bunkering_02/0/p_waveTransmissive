FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      p_waveTransmissive;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    left
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        101325;
        lInf            5;
        value           uniform 101325;
    }
    right
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        101325;
        lInf            5;
        value           uniform 101325;
    }
    front
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        101325;
        lInf            5;
        value           uniform 101325;
    }
    back
    {
        type            totalPressure;
        rho             rho;
        psi             thermo:psi;
        gamma           1.4;
        p0              uniform 101325;
        value           uniform 101325;
    }
    top
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        101325;
        lInf            5;
        value           uniform 101325;
    }
    bottom
    {
        type            zeroGradient;
    }
    bunkering-boat_m
    {
        type            zeroGradient;
    }
    bunkering-quay_m
    {
        type            zeroGradient;
    }
    nozzle
    {
        type            zeroGradient;
    }
    nozzle_holder_wall
    {
        type            zeroGradient;
    }
}


