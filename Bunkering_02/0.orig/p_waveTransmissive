FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform 101325;

boundaryField
{
    right
    {
        type            waveTransmissive;
        field           p;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        101325;
        lInf            5.0; //10.0 length scale over which pressure waves decay
        phi             phi;
        rho             rho;
        value           uniform 101325;
    }        
    left                
    {
        type            waveTransmissive;
        field           p;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        101325;
        lInf            5.0; //10.0 length scale over which pressure waves decay
        phi             phi;
        rho             rho;
        value           uniform 101325;
    }        
    front               
    {
        type            waveTransmissive;
        field           p;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        101325;
        lInf            5.0; //10.0 length scale over which pressure waves decay
        phi             phi;
        rho             rho;
        value           uniform 101325;
    }        
    back                
    {
        type            totalPressure; //waveTransmissive;
        p0              uniform 101325;
        gamma       1.4;
        U           U;
        rho         rho;
        psi         thermo:psi;
        value       uniform 101325;
/*
        field           p;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        101325;
        lInf            5.0; //10.0 length scale over which pressure waves decay
        phi             phi;
        rho             rho;
        value           uniform 101325;
*/        
    }        
    top                 
    {
        type            waveTransmissive;
        field           p;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        101325;
        lInf            5.0; //10.0 length scale over which pressure waves decay
        phi             phi;
        rho             rho;
        value           uniform 101325;
    }        
    bottom             { type zeroGradient; }
    bunkering-boat_m   { type zeroGradient; }
    bunkering-quay_m   { type zeroGradient; }
    nozzle_holder_wall { type zeroGradient; }
    nozzle             { type zeroGradient; }
}
